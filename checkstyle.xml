<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle-Konfiguration für Programmieren 2.
  Prüft grundlegende Java-Konventionen – keine übertrieben strengen Regeln.
-->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="warning"/>

  <!-- Zeilenlänge max 120 Zeichen -->
  <module name="LineLength">
    <property name="max" value="120"/>
  </module>

  <!-- Keine Tab-Zeichen (nur Spaces) -->
  <module name="FileTabCharacter"/>

  <module name="TreeWalker">

    <!-- === Naming Conventions === -->

    <!-- Klassennamen: PascalCase -->
    <module name="TypeName"/>

    <!-- Methoden: camelCase -->
    <module name="MethodName"/>

    <!-- Variablen: camelCase -->
    <module name="LocalVariableName"/>
    <module name="MemberName"/>
    <module name="ParameterName"/>

    <!-- Konstanten: UPPER_SNAKE_CASE -->
    <module name="ConstantName"/>

    <!-- === Imports === -->

    <!-- Keine Wildcard-Imports (import java.util.*) -->
    <module name="AvoidStarImport"/>

    <!-- Keine unbenutzten Imports -->
    <module name="UnusedImports"/>

    <!-- === Whitespace === -->

    <!-- Leerzeichen nach Komma, Semikolon -->
    <module name="WhitespaceAfter">
      <property name="tokens" value="COMMA, SEMI"/>
    </module>

    <!-- Leerzeichen um Operatoren (+, -, =, ==, ...) -->
    <module name="WhitespaceAround">
      <property name="allowEmptyConstructors" value="true"/>
      <property name="allowEmptyMethods" value="true"/>
    </module>

    <!-- === Sonstiges === -->

    <!-- Keine leeren catch-Blöcke -->
    <module name="EmptyCatchBlock">
      <property name="exceptionVariableName" value="expected|ignore"/>
    </module>

    <!-- Eine Klasse pro Datei -->
    <module name="OneTopLevelClass"/>

  </module>
</module>
